{
  "name": "@quelvio/langchain",
  "version": "0.1.0",
  "description": "Quelvio for LangChain.js — your company's brain as a retriever and a tool.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "LICENSE", "CHANGELOG.md"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Quelvio/quelvio-langchain-js.git"
  },
  "homepage": "https://quelvio.com/docs/langchain-js",
  "bugs": {
    "url": "https://github.com/Quelvio/quelvio-langchain-js/issues"
  },
  "keywords": [
    "quelvio",
    "langchain",
    "langchainjs",
    "rag",
    "retrieval",
    "knowledge",
    "enterprise-search",
    "ai-agent"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "pack:dry": "pnpm pack --dry-run"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3.0 <0.4.0"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@langchain/core": "^0.3.30",
    "@types/node": "^20.17.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
